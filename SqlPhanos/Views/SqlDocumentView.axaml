<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SqlPhanos.ViewModels"
             xmlns:editor="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="SqlPhanos.Views.SqlDocumentView"
             x:DataType="vm:SqlDocumentViewModel">

    <Design.DataContext>
        <vm:SqlDocumentViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" 
                Background="{DynamicResource SystemAccentColor}"
                Padding="12,8">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Title}" 
                           FontWeight="SemiBold"
                           FontSize="14"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0"
                           Grid.Column="2"
                           Text="{Binding FilePath}"
                           FontSize="11"
                           Opacity="0.7"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Orientation="Horizontal"
                            Spacing="8"
                            Margin="0,10,0,0">
                    <TextBlock Text="View:"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"/>

                    <Button Command="{Binding ShowOriginalCommand}"
                            Content="Original"
                            IsEnabled="{Binding IsShowingFormatted}" />

                    <Button Command="{Binding ShowFormattedCommand}"
                            Content="Formatted"
                            IsEnabled="{Binding !IsShowingFormatted}" />

                    <Border Background="#33000000"
                            CornerRadius="4"
                            Padding="8,2">
                        <TextBlock Text="{Binding DisplayModeLabel}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <editor:TextEditor x:Name="Editor"
                           FontFamily="Cascadia Code,Cascadia Mono,Consolas,Courier New"
                           FontSize="14"
                           IsReadOnly="True"
                           ShowLineNumbers="True"
                           WordWrap="False"
                           HorizontalScrollBarVisibility="Auto"
                           VerticalScrollBarVisibility="Auto"/>
    </DockPanel>

</UserControl>
